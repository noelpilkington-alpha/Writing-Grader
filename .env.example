# Writing Test Grader — Environment Configuration
# Copy this file to .env and fill in your values.

# Anthropic API key (required for grading)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for grading (default: Sonnet for speed/cost balance)
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6

# API server port
PORT=8000

# API host (use 0.0.0.0 to expose externally)
HOST=127.0.0.1
