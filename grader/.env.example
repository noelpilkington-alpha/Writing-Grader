# Provider: "bedrock" (AWS) or "anthropic" (direct API)
ANTHROPIC_PROVIDER=bedrock

# --- AWS Bedrock settings ---
# AWS credentials are read from the standard AWS credential chain:
#   environment vars (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY),
#   ~/.aws/credentials, IAM role, etc.
AWS_REGION=us-east-1
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# --- Direct Anthropic API settings ---
# ANTHROPIC_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
